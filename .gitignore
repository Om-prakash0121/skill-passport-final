# # Ignore everything
# *

# # But keep frontend folder
# !frontend/
# !frontend/**

# # Keep gitignore itself
# !.gitignore

# # Never upload dependencies or secret files
# frontend/node_modules/
# frontend/.env
# frontend/.env.*
# frontend/dist/
# frontend/build/

# Ignore unnecessary folders/files
node_modules/
.env
.env.*
dist/
build/

# Ignore hidden/generated folders you do not want
.emergent/

# Do NOT ignore these project folders
!frontend/
!memory/
!tests/
!test_reports/

# Ignore node_modules inside frontend
frontend/node_modules/
frontend/.env
frontend/.env.*
frontend/dist/
frontend/build/